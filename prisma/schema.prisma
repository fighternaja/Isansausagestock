generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ItemType {
  RAW_MATERIAL
  PRODUCT
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())

  productionBatches ProductionBatch[]
  stockMovements    StockMovement[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RawMaterial {
  id            String   @id @default(cuid())
  name          String
  unit          String
  quantity      Decimal  @default(0) @db.Decimal(12, 3)
  minStockAlert Decimal  @default(0) @db.Decimal(12, 3)
  costPerUnit   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipeItems              ProductRecipeItem[]
  productionBatchMaterials ProductionBatchMaterial[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  recipe        Json?
  quantity      Decimal  @default(0) @db.Decimal(12, 3)
  minStockAlert Decimal  @default(0) @db.Decimal(12, 3)
  expiryDays    Int      @default(7)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipeItems       ProductRecipeItem[]
  productionBatches ProductionBatch[]
}

model ProductRecipeItem {
  productId       String
  rawMaterialId   String
  quantityPerUnit Decimal @db.Decimal(12, 3)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@id([productId, rawMaterialId])
}

model ProductionBatch {
  id               String   @id @default(cuid())
  productId        String
  quantityProduced Decimal  @db.Decimal(12, 3)
  producedAt       DateTime @default(now())
  totalCost        Decimal  @db.Decimal(12, 2)
  costPerUnit      Decimal  @db.Decimal(12, 2)
  userId           String

  product   Product                   @relation(fields: [productId], references: [id])
  user      User                      @relation(fields: [userId], references: [id])
  materials ProductionBatchMaterial[]

  @@index([productId])
  @@index([userId])
}

model ProductionBatchMaterial {
  batchId       String
  rawMaterialId String
  quantityUsed  Decimal @db.Decimal(12, 3)
  costAtTime    Decimal @db.Decimal(12, 2)

  batch       ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial     @relation(fields: [rawMaterialId], references: [id])

  @@id([batchId, rawMaterialId])
}

model StockMovement {
  id        String       @id @default(cuid())
  itemType  ItemType
  itemId    String
  type      MovementType
  quantity  Decimal      @db.Decimal(12, 3)
  reason    String?
  userId    String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([itemType, itemId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  tableName String
  recordId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
